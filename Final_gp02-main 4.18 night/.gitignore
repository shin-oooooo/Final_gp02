# ── Kronos：仅跟踪默认推理所需（kronos-small + tokenizer-base），其余用 download_kronos_weights 或 Hub ──
kronos_weights/*
!kronos_weights/kronos-small/
!kronos_weights/kronos-small/**
!kronos_weights/tokenizer-base/
!kronos_weights/tokenizer-base/**

# 权重目录内 HuggingFace 下载缓存不上传
kronos_weights/**/.cache/

bin/kronos_weights/

# 其他目录的模型大文件（勿误提交）
*.safetensors
!kronos_weights/kronos-small/model.safetensors
!kronos_weights/tokenizer-base/model.safetensors

*.bin
*.pt
*.pth
*.ckpt
*.onnx

# HuggingFace 本地缓存
.cache/
**/.cache/

